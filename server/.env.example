# SinoPac (Shioaji) backend credentials. Copy to server/.env.
# Get api_key / secret_key from SinoPac e-Leader. CA certificate is NOT needed
# for market data (only for placing orders, which this service never does).
SINOPAC_API_KEY=
SINOPAC_SECRET_KEY=

# Use simulation=true to validate the flow before going live.
SINOPAC_SIMULATION=true

# Seconds to cache a snapshot response (avoids re-hitting the feed on bursts).
SINOPAC_CACHE_TTL=2

# Port uvicorn listens on (must match SINOPAC_BACKEND_URL / Vite proxy target).
PORT=8001

{
  "name": "stock-tracker-dashboard",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest",
    "brief:run": "vite-node scripts/brief-runner.mjs --mode once",
    "brief:due": "vite-node scripts/brief-runner.mjs --mode due",
    "brief:launchd:print": "vite-node scripts/brief-launchd.mjs print",
    "brief:launchd:export": "vite-node scripts/brief-launchd.mjs export",
    "brief:launchd:install": "vite-node scripts/brief-launchd.mjs install",
    "brief:launchd:uninstall": "vite-node scripts/brief-launchd.mjs uninstall"
  },
  "dependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.7.0",
    "@testing-library/react": "^16.3.0",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^5.0.0",
    "jsdom": "^26.1.0",
    "typescript": "~5.8.3",
    "vite": "^7.0.0",
    "vitest": "^3.2.4"
  }
}

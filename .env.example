# Copy this file to .env.local for local development.
# For background runner / launchd, the same variables can also be exported in your shell.

# Frontend live data
VITE_FINNHUB_API_KEY=
VITE_FRED_API_KEY=

# Preferred for local dev proxy and background runner
FUGLE_API_KEY=
OPENAI_API_KEY=

# Optional webhook delivery for brief runner
BRIEF_WEBHOOK_URL=
BRIEF_WEBHOOK_FORMAT=json
SLACK_WEBHOOK_URL=

# Optional frontend proxy / custom endpoint overrides
VITE_TWSE_BASE_URL=
VITE_TWSE_MIS_BASE_URL=
VITE_GOOGLE_NEWS_BASE_URL=
VITE_FUGLE_BASE_URL=
VITE_FRED_BASE_URL=
VITE_SENTIMENT_API_URL=
VITE_SENTIMENT_MODEL=gpt-5-mini

# Optional background runner / launchd endpoint overrides
FINNHUB_API_KEY=
VITE_FUGLE_API_KEY=
FUGLE_BASE_URL=
FRED_API_KEY=
FRED_BASE_URL=
TWSE_BASE_URL=
TWSE_MIS_BASE_URL=
GOOGLE_NEWS_BASE_URL=
SENTIMENT_API_URL=
SENTIMENT_MODEL=gpt-5-mini
